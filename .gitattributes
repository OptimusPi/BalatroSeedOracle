# Auto detect text files and perform LF normalization
* text=auto

# C# and .NET files should use CRLF on Windows
*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf
*.config text eol=crlf
*.axaml text eol=crlf
*.xaml text eol=crlf
*.json text eol=crlf
*.xml text eol=crlf

# Shell scripts should use LF
*.sh text eol=lf

# Documentation can use auto
*.md text=auto

# Binary assets: never text-convert, never diff as text, never touch the bytes.
# (Ten months of silence came from corrupted committed .ogg blobs. Never again.)
*.ogg binary
*.flac binary
*.mp3 binary
*.wav binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
