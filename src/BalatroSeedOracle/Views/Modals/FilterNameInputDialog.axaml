<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BalatroSeedOracle.Views.Modals.FilterNameInputDialog"
             Width="450"
             Height="250"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">

    <Border Background="{StaticResource DarkBorder}"
            BorderBrush="{StaticResource LightGrey}"
            BorderThickness="3"
            CornerRadius="16">
        <Grid RowDefinitions="Auto,*,Auto">
            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource ModalGrey}"
                    CornerRadius="14,14,0,0"
                    Padding="20,12">
                <TextBlock x:Name="TitleTextBlock"
                           Text="Create New Filter"
                           FontSize="24"
                           Foreground="{StaticResource White}"
                           HorizontalAlignment="Center"
                           FontFamily="{StaticResource BalatroFont}"/>
            </Border>

            <!-- Content Area -->
            <Border Grid.Row="1"
                    Background="{StaticResource DarkBackground}"
                    Padding="24">
                <StackPanel Spacing="8">
                    <TextBlock Text="Filter Name:"
                               FontSize="16"
                               Foreground="{StaticResource White}"
                               FontFamily="{StaticResource BalatroFont}"/>
                    <TextBox x:Name="FilterNameTextBox"
                             PlaceholderText="Enter filter name..."
                             Margin="0,10,0,0"
                             FontSize="18"
                             Padding="12,8"
                             MinHeight="45"
                             FontFamily="{StaticResource BalatroFont}"/>
                </StackPanel>
            </Border>

            <!-- Button Area -->
            <Border Grid.Row="2"
                    Background="{StaticResource DarkBackground}"
                    CornerRadius="0,0,14,14"
                    Padding="20,12,20,20">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="12">
                    <Button x:Name="ConfirmButton"
                            Content="CREATE"
                            Classes="btn-blue"
                            MinWidth="120"
                            Height="45"
                            Click="OnConfirmClick"/>
                    <Button x:Name="CancelButton"
                            Content="CANCEL"
                            Classes="btn-red"
                            MinWidth="120"
                            Height="45"
                            Click="OnCancelClick"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
