<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:BalatroSeedOracle.Controls"
             xmlns:components="using:BalatroSeedOracle.Components"
             xmlns:modals="using:BalatroSeedOracle.Views.Modals"
             xmlns:views="using:BalatroSeedOracle.Views"
             xmlns:vm="using:BalatroSeedOracle.ViewModels"
             xmlns:converters="using:BalatroSeedOracle.Converters"
             xmlns:material="clr-namespace:IconPacks.Avalonia.Material;assembly=IconPacks.Avalonia.Material"
             xmlns:feather="clr-namespace:IconPacks.Avalonia.FeatherIcons;assembly=IconPacks.Avalonia.FeatherIcons"
             x:Class="BalatroSeedOracle.Views.BalatroMainMenu"
             x:DataType="vm:BalatroMainMenuViewModel"
             Background="Transparent"
             Focusable="True"
             x:CompileBindings="True">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+F" Command="{Binding SeedSearchCommand}" />
    </UserControl.KeyBindings>

    <UserControl.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
    </UserControl.Styles>

    <Grid>
        <!-- Balatro Shader Background (IsHitTestVisible=False so clicks pass through to UI) -->
        <controls:BalatroShaderBackground x:Name="BackgroundControl"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         IsHitTestVisible="False" />

        <!-- Settings Popup removed - now using modal system -->

        <!-- Volume Slider Popup (shown when music button clicked) -->
        <Popup x:Name="VolumePopup"
               IsOpen="{Binding IsVolumePopupOpen, Mode=TwoWay}"
               Placement="Top"
               PlacementTarget="{Binding ElementName=MusicToggleButton}"
               IsLightDismissEnabled="True">
            <Border Background="{StaticResource DarkBorder}"
                    BorderBrush="{StaticResource ModalBorder}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="15,20">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" Margin="0,0,0,5">
                        <Path Width="14" Height="14" Fill="{StaticResource Gold}" Data="{StaticResource VolumeHighIconData}" VerticalAlignment="Center"/>
                        <TextBlock Text="VOLUME"
                                   FontSize="18"
                                   Foreground="{StaticResource Gold}"/>
                    </StackPanel>

                    <!-- Vertical Volume Slider  -->
                    <Slider x:Name="VolumeSlider"
                            Orientation="Vertical"
                            Minimum="0"
                            Maximum="100"
                            Value="{Binding Volume, Mode=TwoWay}"
                            Height="120"
                            Width="40"
                            ToolTip.Tip="Drag to adjust volume"/>

                    <!-- Volume Percentage Display -->
                    <TextBlock x:Name="VolumePercentText"
                               Text="{Binding VolumePercentText}"
                               FontSize="18"
                               
                               Foreground="White"
                               HorizontalAlignment="Center"/>

                    <!-- Mute Button -->
                    <Button x:Name="MuteButton"
                            Content="{Binding MuteButtonText}"
                            Command="{Binding MuteCommand}"
                            MinWidth="80"
                            Width="80"
                            FontSize="18"
                            Height="30"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Popup>
        
        <!-- Main content that will be blurred when modals are open (hidden in Vibe Out Mode) -->
        <Grid x:Name="MainContent" ZIndex="5" IsVisible="{Binding !IsVibeOutMode}" IsHitTestVisible="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="MainTitleText"
                        Text="{Binding MainTitle}"
                        FontFamily="{StaticResource BalatroFont}"
                        FontSize="36"

                        Foreground="{StaticResource White}"
                        HorizontalAlignment="Center"
                        Margin="0,4,4,4"
                        IsHitTestVisible="False"/>

            <!-- All Docks Container - Anchored to screen edges (always visible so user can toggle widgets) -->
            <Grid Grid.Row="1"
                  VerticalAlignment="Bottom"
                  Margin="0,0,0,40"
                  IsHitTestVisible="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Side Dock (like PROFILE + Fx in real Balatro) - ANCHORED LEFT -->
                <Grid Grid.Column="0"
                      HorizontalAlignment="Left"
                      Margin="20,0,0,0">
                    <!-- Dark shadow underneath -->
                    <Border Background="{StaticResource HoverShadow}"
                            CornerRadius="8"
                            Margin="0,2,0,0"/>
                    <!-- Main dock panel -->
                    <Border Background="{StaticResource ModalGrey}"
                            CornerRadius="8"
                            Padding="4,0,4,2"
                            Margin="0,0,0,4">
                        <StackPanel Orientation="Vertical" Spacing="4">
                            <!-- Author Label -->
                            <TextBlock Text="Author" 
                                        Margin="4,6,4,2"
                                       FontFamily="{StaticResource BalatroFont}"
                                       FontSize="18"
                                       
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource White}"/>
                            
                            <!-- Author Button (Balatro style like language buttons) -->
                            <Button x:Name="AuthorButton"
                                    Width="120"
                                    Height="40"
                                    Command="{Binding AuthorClickCommand}"
                                    Classes="author-button">
                                <Grid>
                                    <!-- Display mode -->
                                    <TextBlock x:Name="AuthorDisplay"
                                               Text="{Binding AuthorName}"
                                               IsVisible="{Binding AuthorDisplayMode}"/>

                                    <!-- Edit mode -->
                                    <TextBox x:Name="AuthorEdit"
                                             Text="{Binding AuthorName, Mode=TwoWay}"
                                             FontSize="18"
                                             BorderThickness="0"
                                             VerticalAlignment="Center"
                                             HorizontalAlignment="Stretch"
                                             TextAlignment="Center"
                                             IsVisible="{Binding AuthorEditMode}"
                                             Focusable="True"
                                             IsHitTestVisible="True"
                                             KeyDown="OnAuthorTextBoxKeyDown"
                                             LostFocus="OnAuthorTextBoxLostFocus"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Main Menu Buttons - Real Balatro dock (gray with drop shadow below) - CENTERED -->
                <Grid Grid.Column="1"
                      HorizontalAlignment="Center">
                    <!-- Dark shadow underneath -->
                    <Border Background="{StaticResource HoverShadow}"
                            CornerRadius="8"
                            Margin="0,4,0,0"/>
                    <!-- Main dock panel -->
                    <Border Background="{StaticResource ModalGrey}"
                            CornerRadius="8"
                            Padding="2"
                            Margin="0,0,0,4">
                
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Classes="btn-green"
                            Command="{Binding SeedSearchCommand}"
                            Content="SEARCH"
                            FontSize="36"
                            MinHeight="60"
                            MinWidth="158"/>

                    <Button Classes="btn-blue"
                            Command="{Binding EditorCommand}"
                            Content="DESIGNER"
                            FontSize="36"
                            MinHeight="46"
                            MinWidth="100"/>

                    <Button Classes="btn-purple"
                            Command="{Binding AnalyzeCommand}"
                            Content="ANALYZER"
                            FontSize="36"
                            MinHeight="46"
                            MinWidth="100"/>

                    <!-- MODS button equivalent - MORE (orange) -->
                    <Button Classes="btn-orange"
                            Command="{Binding ToolCommand}"
                            Content="SETTINGS"
                            FontSize="36"
                            MinHeight="60"
                            MinWidth="158"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Right Side Dock (like Language selector in real Balatro) - ANCHORED RIGHT -->
                <Grid Grid.Column="2"
                      HorizontalAlignment="Right"
                      Margin="0,0,20,0">
                    <!-- Dark shadow underneath -->
                    <Border Background="{StaticResource HoverShadow}"
                            CornerRadius="8"
                            Margin="0,2,0,0"/>
                    <!-- Main dock panel -->
                    <Border Background="{StaticResource ModalGrey}"
                            CornerRadius="8"
                            Padding="6,4,6,6"
                            Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <!-- Pause/Resume Animation Button (square like language buttons) -->
                            <Button x:Name="AnimationToggleButton"
                                    Classes="btn-purple"
                                    FontSize="18"
                                    Width="48"
                                    Height="48"
                                    CornerRadius="8"
                                    BorderBrush="{StaticResource ModalBorder}"
                                    BorderThickness="2"
                                    Margin="0,0,0,2"
                                    Command="{Binding AnimationToggleCommand}"
                                    ToolTip.Tip="Pause/resume background animation">
                                <Path Width="24" Height="24" Fill="{StaticResource White}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path.Styles>
                                        <Style Selector="Path">
                                            <Setter Property="Data" Value="{StaticResource PauseIconData}"/>
                                        </Style>
                                        <Style Selector="Path[Tag=Play]">
                                            <Setter Property="Data" Value="{StaticResource PlayIconData}"/>
                                        </Style>
                                    </Path.Styles>
                                    <Path.Tag>
                                        <Binding Path="AnimationIcon"/>
                                    </Path.Tag>
                                </Path>
                            </Button>

                            <!-- Music Toggle Button -->
                            <Button x:Name="MusicToggleButton"
                                    Classes="btn-purple"
                                    FontSize="18"
                                    Width="48"
                                    Height="48"
                                    CornerRadius="8"
                                    BorderBrush="{StaticResource ModalBorder}"
                                    BorderThickness="2"
                                    Margin="0,0,0,2"
                                    Command="{Binding MusicToggleCommand}"
                                    ToolTip.Tip="Adjust volume">
                                <Path Width="24" Height="24" Fill="{StaticResource White}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path.Styles>
                                        <Style Selector="Path">
                                            <Setter Property="Data" Value="{StaticResource VolumeHighIconData}"/>
                                        </Style>
                                        <Style Selector="Path[Tag=VolumeOff]">
                                            <Setter Property="Data" Value="{StaticResource VolumeOffIconData}"/>
                                        </Style>
                                    </Path.Styles>
                                    <Path.Tag>
                                        <Binding Path="MusicIcon"/>
                                    </Path.Tag>
                                </Path>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid> <!-- End All Docks Container -->
        </Grid> <!-- End MainContent -->

        <!-- Modal overlay container for code-behind modals -->
        <Grid x:Name="ModalContainer"
              IsVisible="{Binding IsModalVisible}"
              ZIndex="100"
              VerticalAlignment="Stretch"
              HorizontalAlignment="Stretch"
              Margin="0">

            <!-- Overlay dimmer - fades in -->
            <Border x:Name="ModalOverlay"
                    Background="{StaticResource SemiTransparentBlack}">
                <!-- Transition removed for now to ensure visibility -->
            </Border>

            <!-- Modal content wrapper - slides up with bounce -->
            <ContentControl x:Name="ModalContentWrapper">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:FilterSelectionModalViewModel">
                        <modals:FilterSelectionModal />
                    </DataTemplate>
                    <DataTemplate DataType="vm:SearchModalViewModel">
                        <modals:SearchModal />
                    </DataTemplate>
                    <DataTemplate DataType="vm:FiltersModalViewModel">
                        <modals:FiltersModal />
                    </DataTemplate>
                    <DataTemplate DataType="vm:SettingsModalViewModel">
                        <modals:SettingsModal />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>

        </Grid>

    </Grid>
</UserControl>
