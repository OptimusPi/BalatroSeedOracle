<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BalatroSeedOracle.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             x:Class="BalatroSeedOracle.Controls.EditionSelector"
             x:DataType="vm:EditionSelectorViewModel"
             d:DataContext="{d:DesignInstance Type=vm:EditionSelectorViewModel}">
    
    <UserControl.Styles>
        <Style Selector="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource BrightGold}"/>
            <Setter Property="Background" Value="{StaticResource SemiTransparentBlack}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentGreen}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontFamily" Value="{StaticResource BalatroFont}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>
        
        <Style Selector="ComboBox:pointerover">
            <Setter Property="BorderBrush" Value="{StaticResource Blue}"/>
        </Style>
        
        <Style Selector="TextBlock.edition-label">
            <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
            <Setter Property="FontFamily" Value="{StaticResource BalatroFont}"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>
        
        <Style Selector="TextBlock.edition-description">
            <Setter Property="Foreground" Value="{StaticResource LightGrey2}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Styles>
    
    <Border Background="{StaticResource SemiTransparentBlack}"
            BorderBrush="{StaticResource AccentGreen}" 
            BorderThickness="2" 
            CornerRadius="8" 
            Padding="15">
        <StackPanel Spacing="12">
            <TextBlock Text="Card Edition" 
                       Classes="edition-label"
                       HorizontalAlignment="Center"/>
            
            <TextBlock Text="What edition should this card have?"
                       Classes="edition-description"
                       HorizontalAlignment="Center"/>
            
            <Grid ColumnDefinitions="*,Auto">
                <ComboBox Name="EditionComboBox"
                          Grid.Column="0"
                          ItemsSource="{Binding Editions}"
                          SelectedItem="{Binding SelectedEdition}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:EditionOptionViewModel">
                            <TextBlock Text="{Binding DisplayName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="1"
                        Content="✕"
                        Command="{Binding ClearEditionCommand}"
                        IsVisible="{Binding HasEditionSelected}"
                        ToolTip.Tip="Clear edition"
                        Margin="4,0,0,0"
                        Padding="8,4"
                        FontSize="14"
                        Foreground="{StaticResource BrightGold}"
                        Background="{StaticResource SemiTransparentBlack}"
                        BorderBrush="{StaticResource AccentGreen}"
                        BorderThickness="1"
                        CornerRadius="4"/>
            </Grid>

            <!-- Edition Description -->
            <Border Background="{StaticResource TransparentDark1}"
                    CornerRadius="5"
                    Padding="10"
                    Name="DescriptionBorder">
                <TextBlock Text="{Binding Description}"
                           Classes="edition-description"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Edition Preview with Effects -->
            <Border Background="{Binding BackgroundColor}"
                    BorderBrush="{Binding BorderColor}"
                    BorderThickness="{Binding BorderThickness}"
                    CornerRadius="8"
                    Padding="15"
                    Name="PreviewBorder"
                    IsVisible="{Binding IsPreviewVisible}">
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="{Binding PreviewEmoji}"
                               Foreground="{Binding PreviewColor}"
                               FontSize="36"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="{Binding PreviewName}"
                               Foreground="{Binding PreviewColor}"
                               FontSize="18"
                               
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="{Binding PreviewEffect}"
                               Classes="edition-description"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
